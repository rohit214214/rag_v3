# Copy to cf.env in the project root and fill in values.
# Loaded by config/cf.py (first existing: cf.env, .env, .env.example).

# --- Hologres (PostgreSQL protocol) — NOT MaxCompute HTTP URL ---
# WRONG (MaxCompute API — do not use for this app):
# HOLOGRES_HOST=http://service.ap-southeast-1.maxcompute.aliyun.com/api
#
# RIGHT: Alibaba Cloud -> Hologres -> your instance -> Connection info -> PostgreSQL
# Copy "Hostname" (ends with .hologres.aliyuncs.com) and port (often 80 or 5432).

# Option A — separate fields (recommended for clarity):
HOLOGRES_HOST=hgpostcn-xxxxx-cn-hangzhou.hologres.aliyuncs.com
HOLOGRES_PORT=80
HOLOGRES_DB=data_center
HOLOGRES_USER=your_hologres_user
HOLOGRES_PASSWORD=your_hologres_password
HOLOGRES_SSLMODE=require

# Option B — full URL from console (must start with postgresql://). If unset or invalid, Option A is used.
# Leave HOLOGRES_URL commented out when using HOLOGRES_HOST / HOLOGRES_PORT / etc.
# HOLOGRES_URL=postgresql://user:password@hgpostcn-xxxxx-cn-hangzhou.hologres.aliyuncs.com:80/data_center?sslmode=require

APP_MAX_ROWS=10000
APP_QUERY_TIMEOUT_SEC=60
APP_DEFAULT_SCHEMA=ads
APP_BUSINESS_RULES_PATH=data/business_rules.json
APP_TABLE_WHITELIST=ads.ads_ckg_sales_di,ads.ads_ckg_traffic_di

# DashScope region: intl (Singapore/international) or cn (China). Key must match region.
DASHSCOPE_REGION=intl

# International endpoint (use with intl API key from dashscope-intl console):
QWEN_ENDPOINT=https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions
# China endpoint (use with China API key):
# QWEN_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

QWEN_API_KEY=sk-your-dashscope-api-key
# Or: DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# Use a model enabled on your account (check DashScope console -> Model list)
QWEN_MODEL=qwen-plus

V_ENDPOINT=
V_API_KEY=
V_MODEL=qwen-turbo
